# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Модели Claude
CLAUDE_MODEL_CHAT=claude-sonnet-4-6
CLAUDE_MODEL_LIGHT=claude-haiku-4-5-20251001

# Сервер
PORT=3001
# Разрешённый origin фронтенда (для CORS)
CLIENT_ORIGIN=http://localhost:5173

# ElevenLabs — озвучка ответов (необязательно).
# Без ключа/голоса озвучка работает системным голосом браузера.
# VOICE_ID берётся из кабинета ElevenLabs (готовый голос или клон).
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_multilingual_v2
