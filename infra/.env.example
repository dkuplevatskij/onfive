# OnFive — Self-hosted Supabase на Timeweb Cloud
# Скопируй в .env и заполни ВСЕ значения перед запуском
# Генерация секретов: openssl rand -base64 32

# ─── Домен и URL ──────────────────────────────────────────────────────────────
# Публичный домен сервера (без слэша)
# Основной домен: onfive.pro | Резервный: onfive.ru (редирект → onfive.pro)
SUPABASE_PUBLIC_URL=https://api.onfive.pro
API_EXTERNAL_URL=https://api.onfive.pro
SITE_URL=https://onfive.pro
# Дополнительные разрешённые redirect URL (через запятую)
ADDITIONAL_REDIRECT_URLS=

# ─── Postgres ─────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_strong_password_here
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# ─── JWT ──────────────────────────────────────────────────────────────────────
# openssl rand -base64 32 → JWT_SECRET
JWT_SECRET=change_me_jwt_secret_min_32_chars
JWT_EXP=3600

# ─── Supabase API Keys ────────────────────────────────────────────────────────
# Генерируй через: https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
# (вставь JWT_SECRET выше в генератор, скопируй anon и service_role)
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Kong Dashboard ───────────────────────────────────────────────────────────
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=change_me_dashboard_password

# ─── Kong Ports ───────────────────────────────────────────────────────────────
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443

# ─── Realtime ─────────────────────────────────────────────────────────────────
# openssl rand -base64 32
REALTIME_ENC_KEY=change_me_realtime_enc_key
# openssl rand -base64 64
REALTIME_SECRET_KEY_BASE=change_me_realtime_secret_key_base

# ─── Analytics ────────────────────────────────────────────────────────────────
# openssl rand -base64 32
LOGFLARE_API_KEY=change_me_logflare_api_key

# ─── SMTP (email-подтверждения, опционально) ──────────────────────────────────
SMTP_ADMIN_EMAIL=noreply@onfive.pro
SMTP_HOST=smtp.timeweb.ru
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# true = не требовать подтверждения email (MVP)
ENABLE_EMAIL_AUTOCONFIRM=true

# ─── Studio ───────────────────────────────────────────────────────────────────
STUDIO_DEFAULT_ORGANIZATION=OnFive
STUDIO_DEFAULT_PROJECT=onfive
